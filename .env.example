# ─── CROO CAP (per-agent) ──────────────────────────────────────────────
# Each of the 5 agents (orchestrator + 4 providers) needs its OWN SDK key.
# A single SDK key allows only ONE live WebSocket connection — a duplicate
# key connection is rejected as a policy violation (ws.ts:96). Do not share.
CROO_API_URL=https://api.croo.network
CROO_WS_URL=wss://api.croo.network/ws

# Orchestrator (requester) key
CROO_SDK_KEY_ORCHESTRATOR=croo_sk_...

# Provider keys
CROO_SDK_KEY_FORENSICS=croo_sk_...
CROO_SDK_KEY_AUDITOR=croo_sk_...
CROO_SDK_KEY_REPUTATION=croo_sk_...
CROO_SDK_KEY_CLAIMS=croo_sk_...

# Target service IDs the orchestrator negotiates with (from the dashboard,
# one per registered provider service).
CROO_SERVICE_ID_FORENSICS=
CROO_SERVICE_ID_AUDITOR=
CROO_SERVICE_ID_REPUTATION=
CROO_SERVICE_ID_CLAIMS=

# Optional: private key (hex) used to sign the Trust Receipt hash. If unset,
# the receipt is emitted unsigned (still hash-anchored). Any funded/unfunded
# key works — this signs the artifact, it does not pay for orders.
RECEIPT_SIGNER_KEY=

# ─── Chain ─────────────────────────────────────────────────────────────
# NOTE: SDK v0.2.0 defaults rpcURL to Base MAINNET (https://mainnet.base.org).
# CAP settlement is real USDC on Base. Confirm the chain in the dashboard
# before funding. Override here only if the dashboard indicates otherwise.
BASE_RPC_URL=https://mainnet.base.org

# ─── LLM (OpenRouter → Gemini) ─────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-...
OPENROUTER_MODEL_STRONG=google/gemini-2.5-pro
OPENROUTER_MODEL_FAST=google/gemini-2.5-flash

# ─── Data sources ──────────────────────────────────────────────────────
# Block-explorer API (BaseScan/Etherscan v2) for forensics + auditor agents.
EXPLORER_API_KEY=
# Web search provider for the reputation agent (e.g. Tavily/Serper).
WEB_SEARCH_API_KEY=
